{
  "name": "layerall",
  "version": "0.1.0",
  "private": true,
  "description": "An agnostic orchestration/abstraction layer for multiple APIs/SDKs — one SDK, many providers, pluggable routing strategies",
  "keywords": [
    "orchestration",
    "abstraction-layer",
    "router",
    "failover",
    "round-robin",
    "load-balance",
    "sdk",
    "multi-provider",
    "typescript"
  ],
  "author": "Sidarta Veloso <sidartaveloso@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sidartaveloso/layerall.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "turbo run test",
    "test:report": "open coverage/index.html",
    "clean": "turbo run clean && rm -rf node_modules .turbo coverage",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:preview": "pnpm --filter docs preview",
    "landing:dev": "pnpm --filter landing dev",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "taskin": "^3.0.3",
    "turbo": "^2.9.18",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}